---
import { getQuizDefaults } from '../lib/config';
import { quizId } from '../lib/id';
import { getTranslate, resolveString } from '../lib/i18n';

interface Props {
  /** A stable id for persistence. Falls back to a hash of the title. */
  id?: string;
  /** A heading shown above the quiz. */
  title?: string;
  /** Extra class names for the quiz wrapper. */
  class?: string;
  /** Shuffle the answer order on each load (choice quizzes only). */
  shuffle?: boolean;
  /**
   * Submit a single-choice quiz as soon as an answer is clicked or tapped
   * (defaults to true; keyboard arrow navigation never auto-submits). Set to
   * false to show a Submit button instead. No effect on multiple-choice or
   * fill-in-the-blank quizzes, which always use a Submit button.
   */
  autoSubmit?: boolean;
  /** Lock the quiz after submitting. When false, a reset button is shown instead. */
  disableAfterSubmit?: boolean;
  /** Highlight the correct answer(s) after an incorrect submission. */
  showCorrect?: boolean;
  /** Prefix the quiz with a "Question N" heading, numbered down the page. */
  autoNumber?: boolean;
  /** Override the submit button label (for vanilla Astro / custom wording). */
  submitLabel?: string;
  /** Override the reset button label. */
  resetLabel?: string;
  /** Override the "correct" feedback message. */
  correctLabel?: string;
  /** Override the "incorrect" feedback message. */
  incorrectLabel?: string;
  /** Override the "try again" feedback message (used when disableAfterSubmit is false). */
  tryAgainLabel?: string;
}

const {
  id,
  title,
  class: className,
  submitLabel,
  resetLabel,
  correctLabel,
  incorrectLabel,
  tryAgainLabel,
} = Astro.props;

// Site-wide defaults (from the plugin) fill in any behaviour prop left unset.
const defaults = getQuizDefaults(Astro.locals);
const shuffle = Astro.props.shuffle ?? defaults.shuffle;
const autoSubmit = Astro.props.autoSubmit ?? defaults.autoSubmit;
const disableAfterSubmit = Astro.props.disableAfterSubmit ?? defaults.disableAfterSubmit;
const showCorrect = Astro.props.showCorrect ?? defaults.showCorrect;
const autoNumber = Astro.props.autoNumber ?? defaults.autoNumber;

const t = getTranslate(Astro.locals);
const resolvedId = quizId(id, title);

const labels = {
  submit: resolveString('starlightQuiz.submit', submitLabel, t),
  reset: resolveString('starlightQuiz.reset', resetLabel, t),
  correct: resolveString('starlightQuiz.correct', correctLabel, t),
  incorrect: resolveString('starlightQuiz.incorrect', incorrectLabel, t),
  tryAgain: resolveString('starlightQuiz.tryAgain', tryAgainLabel, t),
  questionNumber: resolveString('starlightQuiz.questionNumber', undefined, t),
};
---

<sl-quiz
  id={resolvedId}
  class:list={['sl-quiz', className]}
  data-shuffle={shuffle ? 'true' : 'false'}
  data-auto-submit={autoSubmit ? 'true' : 'false'}
  data-disable-after-submit={disableAfterSubmit ? 'true' : 'false'}
  data-show-correct={showCorrect ? 'true' : 'false'}
  data-auto-number={autoNumber ? 'true' : 'false'}
  data-number-label={labels.questionNumber}
  data-submit-label={labels.submit}
  data-reset-label={labels.reset}
  data-correct-label={labels.correct}
  data-incorrect-label={labels.incorrect}
  data-try-again-label={labels.tryAgain}
>
  {title && <p class="sl-quiz-title">{title}</p>}
  <div class="sl-quiz-source"><slot /></div>
</sl-quiz>

<script>
  import { defineQuizElement } from '../lib/quiz-element';

  defineQuizElement();
</script>
